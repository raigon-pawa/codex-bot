# ── Required ──────────────────────────────────────────────
# Developer Portal → Bot → "Reset Token" (copy the token)
DISCORD_TOKEN=

# Developer Portal → General Information → "Application ID"
APPLICATION_ID=

# ── Optional ──────────────────────────────────────────────
# Your TEST server's ID. When set, slash commands sync INSTANTLY
# to that one server. Leave blank for global sync (can take ~1 hour
# the first time). Right-click your server icon → Copy Server ID
# (requires Developer Mode: User Settings → Advanced → Developer Mode).
DEV_GUILD_ID=

# Prefix for legacy text commands (slash commands are primary).
PREFIX=!

# Comma-separated user IDs allowed to run owner-only commands.
OWNER_IDS=

# Path to the SQLite database file.
DB_PATH=data/codex.db

# AI assistance (Claude). Needed only for the AI cog.
ANTHROPIC_API_KEY=
