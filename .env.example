# ── Required ──────────────────────────────────────────────
# Developer Portal → Bot → "Reset Token" (copy the token)
DISCORD_TOKEN=

# Developer Portal → General Information → "Application ID"
APPLICATION_ID=

# ── Optional ──────────────────────────────────────────────
# Legacy: commands now always sync GLOBALLY on startup (every server gets them).
# For instant updates in one server while developing, use the owner command
# `!sync guild` instead. This value is no longer used and can be left blank.
DEV_GUILD_ID=

# Prefix for legacy text commands (slash commands are primary).
PREFIX=!

# Comma-separated user IDs allowed to run owner-only commands.
OWNER_IDS=

# Path to the SQLite database file.
DB_PATH=data/codex.db

# AI assistance (Claude). Needed only for the AI cog.
ANTHROPIC_API_KEY=
# Optional: model + reply length. Default is the cost-effective Haiku tier; switch
# to claude-opus-4-8 (best quality) or claude-sonnet-4-6 (mid) to upgrade.
AI_MODEL=claude-haiku-4-5
AI_MAX_TOKENS=1024

# Premium tier (App Subscriptions). Needed only for the premium cog. Create a
# subscription SKU in Developer Portal → Monetization, then run `/premium skus`
# (owner-only) to get its ID and paste it here.
PREMIUM_SKU_ID=
